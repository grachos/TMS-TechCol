# ==========================================================
#  Light TMS - API backend (Node/Express) configuration.
#  Copy to ".env" and fill in. The server also falls back to
#  the repo-root ".env" (the PHP app's file) for DB/RNDC/COLA
#  values, so you can keep a single source of truth if you like.
# ==========================================================

# --- App ---
APP_NAME="Light TMS"
APP_ENV=local            # local | produccion
APP_DEBUG=true
PORT=4000
# Comma-separated origins allowed by CORS (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES=8h

# --- Database (mirrors the PHP .env) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=light_tms
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- RNDC web service ---
# Username/password/NIT are no longer set here — they're edited in the
# "Empresa" form (admin only) and stored in maestro_empresa.
RNDC_AMBIENTE=pruebas
RNDC_HOST_OVERRIDE=
RNDC_TIMEOUT=30

# --- Queue / retries ---
COLA_MAX_INTENTOS=10
COLA_MINUTOS_REINTENTO=15
# Safety switch: false (default) builds & previews XML but does NOT send to RNDC.
COLA_ENVIO_HABILITADO=false

# --- Chatbot de datos (OpenRouter, API compatible con OpenAI) ---
# Opt-in: queda deshabilitado hasta poner CHAT_HABILITADO=true + una API key.
CHAT_HABILITADO=false
OPENROUTER_API_KEY=
# Modelo con soporte de "tool calling". Con uno :free el backend añade otros
# modelos gratis de respaldo (fallback automático de OpenRouter) porque el tier
# gratis se satura seguido. Ejemplos:
#   meta-llama/llama-3.3-70b-instruct:free   (gratis)
#   qwen/qwen3-coder:free                     (gratis)
#   deepseek/deepseek-chat-v3-0324            (de pago, muy barato y estable)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CHAT_MAX_FILAS=200
# Usuario de BD de SOLO LECTURA para el chatbot (mínimo privilegio).
# Si se dejan vacíos, usa DB_USER/DB_PASS. Recomendado crear un usuario con
# GRANT SELECT solo sobre las tablas no sensibles (ver chat.repo.ts).
DB_READONLY_USER=
DB_READONLY_PASS=
