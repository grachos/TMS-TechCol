{
  "name": "tms-light-server",
  "version": "1.0.0",
  "private": true,
  "description": "Light TMS - API backend (Node + Express + TypeScript + mysql2). Port of the PHP app.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && npm run build:copy-assets",
    "build:copy-assets": "node -e \"const fs=require('fs');fs.mkdirSync('dist/modules/pdf/assets',{recursive:true});fs.copyFileSync('src/modules/pdf/render-worker.mjs','dist/modules/pdf/render-worker.mjs');for(const f of fs.readdirSync('src/modules/pdf/assets'))fs.copyFileSync('src/modules/pdf/assets/'+f,'dist/modules/pdf/assets/'+f)\"",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx src/queue/worker.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.5",
    "puppeteer-core": "^23.11.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
